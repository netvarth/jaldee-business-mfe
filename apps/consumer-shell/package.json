{
  "name": "consumer-shell",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "clean": "node -e \"const fs = require('fs'); ['dist', 'build'].forEach(d => fs.rmSync(d, { recursive: true, force: true }));\"",
    "dev": "vite --port 3010 --strictPort",
    "build": "vite build",
    "preview": "vite preview --port 3010 --strictPort",
    "serve": "npm run build && vite preview --port 3010 --strictPort"
  },
  "dependencies": {
    "@jaldee/api-client": "*",
    "posthog-js": "^1.393.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router-dom": "6.22.3",
    "zustand": "4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "18.2.79",
    "@types/react-dom": "18.2.25",
    "@vitejs/plugin-react": "4.3.4",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "5.4.5",
    "vite": "5.2.14"
  }
}

{
  "name": "@jaldee/design-system",
  "version": "1.0.0",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./src/tokens.css": "./src/tokens.css"
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "preview:dev": "vite --config vite.preview.config.ts",
    "preview:build": "vite build --config vite.preview.config.ts",
    "preview": "vite preview --config vite.preview.config.ts --strictPort --port 4100"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "1.0.5",
    "@radix-ui/react-select": "2.0.0",
    "class-variance-authority": "0.7.0",
    "clsx": "2.1.1",
    "tailwind-merge": "2.3.0"
  },
  "peerDependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "4.3.4",
    "@types/react": "18.2.79",
    "@types/react-dom": "18.2.25",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "5.4.5",
    "vite": "5.2.14"
  }
}
